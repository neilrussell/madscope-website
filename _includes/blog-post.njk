<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Madscope Marketing</title>
  <meta name="description" content="{{ description }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://madscopemarketing.com/blog/{{ slug }}/">
  <meta property="og:title" content="{{ title }} | Madscope Marketing">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="https://madscopemarketing.com/blog/{{ slug }}/">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Madscope Marketing">
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">
      <img src="/images/logo.png" alt="Madscope Marketing logo">
      <span class="nav-logo-text">Madscope Marketing</span>
    </a>
    <ul class="nav-links">
      <li><a href="/how-it-works/">How It Works</a></li>
      <li><a href="/results/">Results</a></li>
      <li><a href="/pricing/">Pricing</a></li>
      <li class="nav-dropdown">
        <button class="nav-dropdown-toggle">
          Industries
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="nav-dropdown-menu">
          <a href="/martial-arts/">Martial Arts <span class="tag">Active</span></a>
        </div>
      </li>
      <li><a href="/blog/" class="active">Blog</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/contact/" class="btn btn-primary">Book a Free Call</a>
    </div>
    <button class="nav-toggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <article>
    <div class="post-header">
      <span class="eyebrow">{{ category }}</span>
      <h1>{{ title }}</h1>
      <p class="post-meta">{{ date | date("D MMMM YYYY") }} &middot; {{ readTime }} read</p>
    </div>
    <div class="post-body">
      {{ content | safe }}
    </div>
  </article>

  <section class="cta-section">
    <div class="cta-inner">
      <span class="eyebrow">You don't pay until they show</span>
      <h2>Ready to Fill Your <span class="accent">Trial Classes?</span></h2>
      <p>Book a free 15-minute call. No pitch deck, no pressure. We'll tell you exactly how many students we think we can deliver in your market.</p>
      <div class="cta-actions">
        <a href="/contact/" class="btn btn-primary btn-lg">Book a Free Call</a>
        <a href="/results/" class="btn btn-ghost btn-lg">See Our Results</a>
      </div>
      <p class="cta-footnote">Pay per show. If they don't walk through the door, you don't owe us a thing.</p>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-brand-logo">
            <img src="/images/logo.png" alt="Madscope Marketing">
            <span>Madscope Marketing</span>
          </div>
          <p>The only pay-per-show student enrollment system for martial arts schools.</p>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/results/">Results</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            <li><a href="/how-it-works/">How It Works</a></li>
            <li><a href="/pricing/">Pricing</a></li>
            <li><a href="/martial-arts/">Martial Arts</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy/">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Madscope Marketing. All rights reserved.</p>
        <p>Students on Tap &mdash; Pay Per Show</p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
